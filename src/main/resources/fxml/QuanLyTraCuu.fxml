<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="ui.TraCuu"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-background-color: #f5f5f5;"
      spacing="20">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <children>
            <Label text="Tra cứu" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </children>
    </HBox>

    <!-- Container chính với 2 phần CHIA ĐỀU -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        
        <!-- ========== PHẦN BÊN TRÁI - HÓA ĐƠN (50%) ========== -->
        <VBox spacing="15" 
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" 
              HBox.hgrow="ALWAYS"
              prefWidth="0"
              minWidth="0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <!-- Header Hóa đơn -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <Label text="Hóa đơn" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    
                    <!-- ComboBox sắp xếp -->
                    <ComboBox fx:id="cboSapXepHD" 
                              promptText="Sắp xếp..."
                              prefWidth="120">
                        <HBox.margin>
                            <Insets left="10"/>
                        </HBox.margin>
                    </ComboBox>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <!-- Search Box -->
                    <TextField fx:id="txtTimKiemHD" 
                              promptText="Tìm SĐT hoặc mã HD..."
                              prefWidth="200">
                    </TextField>
                </children>
            </HBox>

            <!-- Bảng Hóa đơn -->
            <TableView fx:id="tblHoaDon" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMaHD" text="Mã HD" prefWidth="80"/>
                    <TableColumn fx:id="colNgayHD" text="Ngày" prefWidth="90"/>
                    <TableColumn fx:id="colHinhThuc" text="PTTT" prefWidth="100"/>
                    <TableColumn fx:id="colSDTKH" text="SĐT KH" prefWidth="100"/>
                    <TableColumn fx:id="colTongTien" text="Tổng tiền" prefWidth="110"/>
                    <TableColumn fx:id="colXemChiTiet" text="Chi tiết" prefWidth="70"/>
                </columns>
                <placeholder>
                    <Label text="Nhập SĐT hoặc mã để tìm kiếm"/>
                </placeholder>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <!-- Nút Xuất Excel -->
            <HBox alignment="CENTER_RIGHT">
                <children>
                    <Button text="📊 Xuất Excel" 
                            onAction="#handleXuatExcelHoaDon"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </children>
            </HBox>
            
        </VBox>

        <!-- ========== PHẦN BÊN PHẢI - KHÁCH HÀNG (50%) ========== -->
        <VBox spacing="15" 
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" 
              HBox.hgrow="ALWAYS"
              prefWidth="0"
              minWidth="0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <!-- Header Khách hàng -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <Label text="Khách hàng" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    
                    <!-- ComboBox sắp xếp -->
                    <ComboBox fx:id="cboSapXepKH" 
                              promptText="Sắp xếp..."
                              prefWidth="120">
                        <HBox.margin>
                            <Insets left="10"/>
                        </HBox.margin>
                    </ComboBox>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <!-- Search Box -->
                    <TextField fx:id="txtTimKiemKH" 
                              promptText="Tìm SĐT hoặc tên KH..."
                              prefWidth="200">
                    </TextField>
                </children>
            </HBox>

            <!-- Bảng Khách hàng -->
            <TableView fx:id="tblKhachHang" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMaKH" text="Mã KH" prefWidth="70"/>
                    <TableColumn fx:id="colHoTen" text="Họ tên" prefWidth="120"/>
                    <TableColumn fx:id="colSDT" text="SĐT" prefWidth="100"/>
                    <TableColumn fx:id="colDiaChi" text="Địa chỉ" prefWidth="120"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="120"/>
                    <TableColumn fx:id="colNgayDK" text="Ngày ĐK" prefWidth="90"/>
                    <TableColumn fx:id="colLoaiKH" text="Loại" prefWidth="70"/>
                    <TableColumn fx:id="colTongTienHD" text="Tổng tiền" prefWidth="100"/>
                    <TableColumn fx:id="colLichSu" text="Lịch sử" prefWidth="70"/>
                </columns>
                <placeholder>
                    <Label text="Nhập SĐT hoặc tên để tìm kiếm"/>
                </placeholder>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <!-- Nút Xuất Excel -->
            <HBox alignment="CENTER_RIGHT">
                <children>
                    <Button text="📊 Xuất Excel" 
                            onAction="#handleXuatExcelKhachHang"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </children>
            </HBox>
            
        </VBox>
        
    </HBox>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
</VBox>