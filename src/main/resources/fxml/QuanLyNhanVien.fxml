<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="ui.NhanVienController" styleClass="nhan-vien-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" BorderPane.alignment="CENTER_LEFT">
            <Button fx:id="btnDanhSach" text="Danh sách NV" onAction="#handleChuyenSangDanhSach" styleClass="tab-button" />
            <Button fx:id="btnPhanCa" text="Phân ca trực" onAction="#handleChuyenSangPhanCa" styleClass="tab-button" />
        </HBox>
    </top>
    
    <center>
        <BorderPane fx:id="contentPane" />
    </center>


</BorderPane>