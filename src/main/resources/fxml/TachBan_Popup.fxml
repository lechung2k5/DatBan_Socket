<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="750.0" spacing="15.0" styleClass="popup-root" stylesheets="@../css/TachBanPopup.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.TachBanPopupController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="popup-title" text="Tách Bàn &amp; Thanh Toán Món Lẻ" />
      <GridPane hgap="10.0" prefHeight="35.0" vgap="5.0">
         <children>
            <Label text="Hóa đơn gốc:" />
            <Label fx:id="lblMaHDGoc" style="-fx-font-weight: bold;" text="HD..." GridPane.columnIndex="1" />
         </children>
      </GridPane>
      
      <HBox alignment="CENTER_LEFT" spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Món ăn trong Hóa đơn gốc:" />
                  <TableView fx:id="tblMonAnGoc" prefHeight="200.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colTenMonGoc" prefWidth="180.0" text="Tên Món" />
                        <TableColumn fx:id="colSLHienTai" prefWidth="50.0" text="SL Gốc" />
                        <TableColumn fx:id="colSLTach" prefWidth="50.0" text="SL Tách" />
                        </columns>
                       <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                       </columnResizePolicy>
                  </TableView>
                  <Button fx:id="btnThanhToanGoc" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="payment-button" text="Thanh Toán HĐ Gốc" />
               </children>
            </VBox>
            
            <VBox styleClass="vbox-actions" alignment="CENTER" spacing="10.0">
                <children>
                    <Label text="Thao tác" style="-fx-font-weight: bold; -fx-text-fill: #4e342e;" />
                    <Button fx:id="btnChuyenChon" mnemonicParsing="false" styleClass="action-button" text="Chuyển &gt;" />
                    <Button fx:id="btnHuyChuyen" mnemonicParsing="false" styleClass="action-button" text="&lt; Hủy Chuyển" />
                </children>
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Món ăn chuyển sang Hóa đơn MỚI:" />
                  <TableView fx:id="tblMonAnMoi" prefHeight="200.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colTenMonMoi" prefWidth="180.0" text="Tên Món" />
                        <TableColumn fx:id="colSLMoi" prefWidth="50.0" text="SL Mới" />
                     </columns>
                       <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                       </columnResizePolicy>
                  </TableView>
                  <Button fx:id="btnThanhToanMoi" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="payment-button" text="Thanh Toán HĐ Mới" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
             <Label fx:id="lblTongTienMoi" style="-fx-font-weight: bold;" text="Tổng tiền món mới: 0 Đ">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" /> 
             <Button fx:id="btnXacNhanTach" mnemonicParsing="false" style="-fx-background-color: #2f9e44; -fx-text-fill: white; -fx-font-weight: bold;" text="Xác nhận Tách (Không TT)" />
             <Button fx:id="btnHuy" mnemonicParsing="false" styleClass="cancel-button" text="Hủy/Đóng" />
           
         </children>
      </HBox>
   </children>
</VBox>