<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.canvas.Canvas?>

<VBox fx:id="rootDashboardVBox" 
      xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="ui.DashboardController" 
      styleClass="dashboard-container" 
      spacing="20.0"
      stylesheets="@../css/DashBoard.css">
    
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <children>
            <VBox>
                <Label text="Màn hình chính" styleClass="screen-title" />
                <Label text="Tổng quan hoạt động hôm nay" style="-fx-text-fill: #7f8c8d;"/>
            </VBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Button text="↻ Làm mới" onAction="#refreshData" style="-fx-font-size: 13px; -fx-cursor: hand;">
                <tooltip><Tooltip text="Cập nhật dữ liệu mới nhất"/></tooltip>
            </Button>
            
            <Label fx:id="lblDateTime" text="Loading..." style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-background-color: #ecf0f1; -fx-padding: 5 15; -fx-background-radius: 15;" />
        </children>
    </HBox>

    <HBox alignment="TOP_LEFT" spacing="20.0">
        <children>
            <VBox spacing="15.0" minWidth="300">
                <children>
                    <VBox fx:id="vboxKiemKeDauCa" styleClass="cash-check-container">
                        <children>
                            <Label text="Kiểm kê đầu ca" styleClass="cash-check-title" />
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <TextField fx:id="txtSoTienKiemKe" promptText="Nhập số tiền..." styleClass="cash-check-field" HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnXacNhanKiemKe" text="Lưu" styleClass="cash-check-button" onAction="#handleCheckCash" />
                            </HBox>
                        </children>
                    </VBox>

                    <VBox fx:id="vboxTienMatTongKet" styleClass="cash-summary-container" managed="false" visible="false">
                        <Label text="Thông tin két tiền" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #27ae60;"/>
                        
                        <GridPane vgap="8" hgap="10">
                            <Label text="Đầu ca:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="cash-summary-label"/>
                            <Label fx:id="lblTienMatDauCa" text="0 đ" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="cash-summary-value-small"/>
                            
                            <Label text="Đã thu:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="cash-summary-label"/>
                            <Label fx:id="lblTienMatThuDuoc" text="0 đ" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="cash-summary-value-small"/>
                            
                            <Label text="Dự kiến:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="cash-summary-label-bold"/>
                            <Label fx:id="lblTienMatDuKien" text="0 đ" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="cash-summary-value-bold"/>
                        </GridPane>
                    </VBox>
                </children>
            </VBox>

            <HBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="TOP_RIGHT">
                <children>
                    <VBox styleClass="stats-card-dayoff" alignment="CENTER">
                        <Label text="Số ngày nghỉ" styleClass="stats-label" />
                        <Label fx:id="lblSoNgayNghi" text="0/5" styleClass="stats-value" />
                    </VBox>
                    <VBox styleClass="stats-card-serving" alignment="CENTER">
                        <Label text="Bàn đang phục vụ" styleClass="stats-label" />
                        <Label fx:id="lblBanPhucVu" text="0" styleClass="stats-value" />
                    </VBox>
                    <VBox styleClass="stats-card-reserved" alignment="CENTER">
                        <Label text="Bàn đặt trước" styleClass="stats-label" />
                        <Label fx:id="lblBanDatTruoc" text="0/20" styleClass="stats-value" />
                    </VBox>
                    <VBox styleClass="stats-card-hours" alignment="CENTER">
                        <Label text="Tổng giờ làm" styleClass="stats-label" />
                        <Label fx:id="lblTongGioLam" text="0h" styleClass="stats-value" />
                    </VBox>
                </children>
            </HBox>
        </children>
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <children>
            <VBox styleClass="calendar-container" HBox.hgrow="ALWAYS" spacing="10.0">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Lịch làm việc tuần này" styleClass="calendar-header-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <DatePicker fx:id="datePicker" styleClass="date-picker-control" onAction="#updateCalendarFromDatePicker" />
                    
                    <Button text="&lt;" onAction="#handlePreviousWeek" styleClass="calendar-nav-button"/> 
                    <Button text="Hôm nay" onAction="#handleCurrentWeek" styleClass="calendar-nav-button"/>
                    <Button text="&gt;" onAction="#handleNextWeek" styleClass="calendar-nav-button"/>
                </HBox>
                
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <content>
                        <GridPane fx:id="weeklyCalendarGrid" styleClass="weekly-calendar-grid" />
                    </content>
                </ScrollPane>
            </VBox>

            <VBox spacing="15.0" minWidth="320" maxWidth="350">
                <children>
                   <VBox styleClass="table-map-container" spacing="10.0" VBox.vgrow="ALWAYS">
                        <Label text="Trạng thái bàn ăn" styleClass="section-title" />
                        
                        <HBox spacing="15.0">
                            <HBox spacing="5" alignment="CENTER_LEFT">
                                <Region style="-fx-background-color: #2ecc71; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 3;" />
                                <Label text="Trống" style="-fx-font-size: 11px;"/>
                            </HBox>
                            <HBox spacing="5" alignment="CENTER_LEFT">
                                <Region style="-fx-background-color: #9b59b6; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 3;" />
                                <Label text="Đã đặt" style="-fx-font-size: 11px;"/>
                            </HBox>
                            <HBox spacing="5" alignment="CENTER_LEFT">
                                <Region style="-fx-background-color: #e74c3c; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 3;" />
                                <Label text="Đang phục vụ" style="-fx-font-size: 11px;"/>
                            </HBox>
                        </HBox>
                        
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" 
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                            <content>
                                <GridPane fx:id="tableMapGrid" styleClass="table-map-grid" alignment="TOP_CENTER" hgap="8.0" vgap="8.0" />
                            </content>
                            <padding>
                                <Insets top="5" right="5" bottom="5" left="5"/>
                            </padding>
                        </ScrollPane>
                    </VBox>

                    <VBox styleClass="kpi-container" spacing="10.0" minHeight="200" VBox.vgrow="NEVER">
                        <Label text="KPI Cá nhân tháng này" styleClass="section-title" />
                        
                        <HBox spacing="15.0" alignment="CENTER">
                            <VBox alignment="CENTER" spacing="2.0"> <Canvas fx:id="hoursCanvas" width="80" height="80" styleClass="kpi-canvas"/>
                                
                                <Label fx:id="hoursDetailsLabel" text="0/0 giờ" styleClass="kpi-detail-label" style="-fx-font-size: 11px; -fx-padding: 3 0 0 0;"/>
                                
                                <Label text="Giờ công" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #2c3e50;"/>
                            </VBox>
                            
                            <VBox alignment="CENTER" spacing="2.0"> <Canvas fx:id="revenueCanvas" width="80" height="80" styleClass="kpi-canvas"/>
                                
                                <Label fx:id="revenueDetailsLabel" text="0/0 đ" styleClass="kpi-detail-label" style="-fx-font-size: 11px; -fx-padding: 3 0 0 0;"/>
                                
                                <Label text="Doanh thu" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #2c3e50;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </children>
            </VBox>
        </children>
    </HBox>
</VBox>