<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<HBox spacing="15" styleClass="root-pane" stylesheets="@../css/DatBan.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.DatBan">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   
   <VBox spacing="15" styleClass="left-panel" HBox.hgrow="NEVER" prefWidth="300.0">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <HBox alignment="CENTER_LEFT" spacing="10">
         <Label styleClass="screen-title-new" text="Danh sách đặt bàn" />
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="10">
         <ComboBox fx:id="comboFilter" prefWidth="120.0" promptText="Đang phục vụ..." styleClass="filter-combo-new" />
         <HBox styleClass="search-container-new" HBox.hgrow="ALWAYS">
            <Label styleClass="search-icon-new" />
            <TextField fx:id="txtSearch" promptText="0377019956" styleClass="search-field-new" />
         </HBox>
      </HBox>
      <ScrollPane fitToWidth="true" styleClass="card-scroll-pane" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="vboxBookingCards" spacing="15" />
         </content>
      </ScrollPane>
   </VBox>

   <ScrollPane fx:id="middleScrollPane" fitToWidth="true" styleClass="middle-scroll-pane" HBox.hgrow="ALWAYS">
      <content>
         <VBox spacing="15">
             <HBox spacing="10" alignment="CENTER_LEFT" styleClass="time-filter-container">
                  <Label text="Thời gian:"/>
                  <ComboBox fx:id="comboThoiGian" prefWidth="90.0" promptText="Giờ" style="-fx-background-color: white; -fx-background-radius: 5;"/>
                  <DatePicker fx:id="datePickerThoiGianDen" prefWidth="110.0" promptText="Chọn ngày"/>
                  
                  <Label text="Số lượng người:"/>
                  <TextField fx:id="txtSoLuongKhach" prefWidth="50.0" promptText="SL" style="-fx-alignment: CENTER;"/>
                  <Label text="Khu vực:"/>
                  <ComboBox fx:id="comboKhuVuc" prefWidth="110.0" promptText="Khu vực" style="-fx-background-color: white; -fx-background-radius: 5;"/>
				  <Region HBox.hgrow="ALWAYS" />
				  <Button fx:id="btnTim" text="Tìm" styleClass="confirm-button"/>
       
             </HBox>
  
            <VBox styleClass="table-grid-container" spacing="10">
               <Label styleClass="form-title" text="Danh sách bàn" alignment="CENTER" maxWidth="Infinity"/>
               
               <VBox spacing="5" alignment="CENTER_LEFT" style="-fx-padding: 10 0 10 0; -fx-border-color: #ced4da; -fx-border-width: 1 0 1 0;">
                   <HBox spacing="10">
                       <Label text="Bàn đang chọn:" style="-fx-font-weight: bold;"/>
                       <Label fx:id="lblBanDangChon" text="Chưa chọn" style="-fx-font-weight: bold; -fx-text-fill: #2f9e44;"/>
                       <Region HBox.hgrow="ALWAYS" />
                       <Label text="Trạng thái:" />
                       <Label fx:id="lblTrangThaiBan" text="Trống" />
                   </HBox>
             </VBox>
               <HBox alignment="CENTER" spacing="20">
                  <VBox alignment="TOP_CENTER" spacing="10">
                     <Label text="Tầng trệt" styleClass="floor-title"/>
                     <GridPane fx:id="gridTangTret" hgap="10" vgap="10" />
                  </VBox>
                  <Region styleClass="vertical-divider" />
                  <VBox alignment="TOP_CENTER" spacing="10">
                     <Label text="Tầng 1" styleClass="floor-title"/>
                     <GridPane fx:id="gridTang1" hgap="10" vgap="10" />
                     <Label text="Phòng riêng" styleClass="floor-title"/>
                     <GridPane fx:id="gridPhongRieng" hgap="10" vgap="10" />
                  </VBox>
               </HBox>
               
               <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15 0 0 0;">
                   <HBox alignment="CENTER" spacing="5">
                       <Rectangle fill="WHITE" height="20.0" styleClass="legend-box" width="20.0" />
                       <Label text="Bàn trống" />
                   </HBox>
                   <HBox alignment="CENTER" spacing="5">
                       <Rectangle fill="#d00000" height="20.0" styleClass="legend-box" width="20.0" /> <Label text="Đã đặt" />
                   </HBox>
                   <HBox alignment="CENTER" spacing="5">
                       <Rectangle fill="#ff9100" height="20.0" styleClass="legend-box" width="20.0" /> <Label text="Đang phục vụ" />
                   </HBox>
                   <HBox alignment="CENTER" spacing="5">
                       <Rectangle fill="#b9f6ca" height="20.0" styleClass="legend-box" width="20.0" />
                       <Label text="Đang chọn" />
                   </HBox>
               </HBox>
                <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                    <Button fx:id="btnXacNhanBan" mnemonicParsing="false" text="Xác nhận" styleClass="confirm-button-large" />
                </HBox>
            </VBox>
      
            <VBox styleClass="info-form-container" spacing="10">
               <Label styleClass="form-title" text="Nhập thông tin" />
               <VBox spacing="10.0">
                  <children>
                     <HBox spacing="15.0">
                        <children>
                           <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                               <Label text="Số điện thoại" />
                               <TextField fx:id="txtSoDienThoai" promptText="Nhập số điện thoại (VD:0377019956)" />
                           </VBox>
                           <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <Label text="Tên khách hàng" />
                                <TextField fx:id="txtTenKhachHang" promptText="Nhập tên khách hàng (VD: Anh Nam)" />
                           </VBox>
                        </children>
                     </HBox>
                     <HBox spacing="15.0">
                        <children>
                           <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                              <children>
                                 <Label text="Yêu cầu đặc biệt" />
                                 <TextField fx:id="txtYeuCau" promptText="Yêu cầu về bàn ăn,..." />
                              </children>
                           </VBox>
                        </children>
                     </HBox>
                     <HBox alignment="BOTTOM_LEFT" spacing="10.0">
                         <children>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                               <children>
                                 <Label text="Tiền cọc bàn" />
                                 <TextField fx:id="txtTienCoc" promptText="150.000 VNĐ" />
                              </children>
                           </VBox>
                           <Button fx:id="btnThanhToanCoc" mnemonicParsing="false" styleClass="payment-button" text="Thanh toán tiền cọc" />
                         </children>
                     </HBox>
                     <HBox spacing="10" alignment="CENTER_LEFT">
					    <Label text="Trạng thái:" />
					    <ComboBox fx:id="comboTrangThaiHienTai" prefWidth="150.0" />
					    <Button fx:id="btnCapNhatTrangThai" text="Cập nhật" styleClass="action-button" />
					</HBox>
                  </children>
              </VBox>
            </VBox>
             
            <VBox styleClass="order-container" spacing="8">
                 <Label styleClass="form-title" text="Gọi món"/>
                
				<HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="section-title-goimon" text="Danh mục món" />
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <HBox styleClass="order-search-bar" alignment="CENTER_LEFT" spacing="5">
                       <Label styleClass="search-icon-new"/> 
                       <TextField fx:id="txtTimMon" promptText="Lẩu cua đồng" style="-fx-background-color: transparent;"/> 
                     </HBox>
                </HBox>
               
                 <HBox styleClass="menu-tabs" spacing="5">
                     <ToggleButton fx:id="toggleKhaiVi" text="Khai vị" selected="true"/>
                     <ToggleButton fx:id="toggleNuong" text="Nướng" />
                     <ToggleButton fx:id="toggleLau" text="Lẩu" />
                     <ToggleButton fx:id="toggleXaoHap" text="Xào/Hấp" />
                     <ToggleButton fx:id="toggleChien" text="Chiên" />
                     <ToggleButton fx:id="toggleDacSan" text="Đặc sản" />
                     <ToggleButton fx:id="toggleDoUong" text="Đồ uống" />
                 </HBox>
				<TableView fx:id="tblMonAn" prefHeight="150.0">
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                     <columns>
                         <TableColumn fx:id="colTenMon" text="Tên món" prefWidth="200"/> 
                         <TableColumn fx:id="colHinhAnh" text="Hình ảnh" prefWidth="80" style="-fx-alignment: CENTER;"/>
                         <TableColumn fx:id="colGia" text="Giá" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                         <TableColumn fx:id="colChon" text="Chọn" prefWidth="80" style="-fx-alignment: CENTER;"/>
                     </columns>
                 </TableView>

                 <Label text="Danh sách order" styleClass="section-title-goimon"/>
                 
                 <TableView fx:id="tblMonDaChon" prefHeight="150.0">
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                     <columns>
                        <TableColumn fx:id="colOrderTenMon" text="Tên món" prefWidth="200"/>
                        <TableColumn fx:id="colOrderDonGia" text="Đơn giá" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                        <TableColumn fx:id="colOrderSoLuong" text="SL" prefWidth="50" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colOrderTangGiam" text="Tăng/Giảm" prefWidth="100" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colOrderHuy" text="Xóa" prefWidth="60" style="-fx-alignment: CENTER;"/>
                     </columns>
                 </TableView>
                <VBox spacing="8" style="-fx-padding: 10 0 0 0;">
                    <!-- Hàng 1: Thao tác chính trên bàn -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Button fx:id="btnSuaMon" mnemonicParsing="false" text="Sửa món" styleClass="action-button-edit" />
                        <Button fx:id="btnDoiBan" mnemonicParsing="false" text="Đổi Bàn" styleClass="action-button-switch" />
                        <Button fx:id="btnTachBan" mnemonicParsing="false" text="Tách Bàn" styleClass="action-button-split" />
                        <Button fx:id="btnGopBan" mnemonicParsing="false" text="Gộp Bàn" styleClass="action-button-merge" />
                        <Button fx:id="btnHuyBan" mnemonicParsing="false" text="Hủy Bàn" styleClass="action-button-cancel" />

                    </HBox>
                    
                    <!-- Hàng 2: Lưu và Thanh toán -->
                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <Button fx:id="btnLuuMon" text="Lưu món" styleClass="action-button-save-items"/>
                        <Button fx:id="btnLuuDatHang" text="Lưu đặt hàng" styleClass="action-button-save"/>
                        <Button fx:id="btnThanhToan" text="Thanh toán" styleClass="confirm-button"/>
                    </HBox>
                </VBox>
            </VBox>
         </VBox>
      </content>
   </ScrollPane>
  
   <ScrollPane fx:id="vboxReceipt" fitToWidth="true" styleClass="receipt-scroll-pane" prefWidth="420" HBox.hgrow="NEVER">
      <content>
         <VBox spacing="10" styleClass="receipt-panel">
             <Label text="HÓA ĐƠN" styleClass="receipt-main-title"/>
             <VBox alignment="CENTER" spacing="1">
                 <Label text="NHÀ HÀNG TỨ HỮU" styleClass="receipt-restaurant-name"/>
                 <Label text="Đ/c: 77 Hồ Tùng Mậu, Phường Châu Đốc, An Giang"/>
                 <Label text="SĐT: 0377019958"/>
             </VBox>
             <Label text="HÓA ĐƠN THANH TOÁN" styleClass="receipt-title"/>
            <Label fx:id="lblSoHD" text="Số HĐ: HD000123"/>
			<GridPane hgap="10">
			   <children>
			       <Label fx:id="lblBanHD" text="Bàn: N/A" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
			       <Label fx:id="lblThuNgan" text="Thu ngân: N/A" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
			       <Label fx:id="lblGioVao" text="Giờ vào: N/A" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
			       <Label fx:id="lblGioRa" text="Giờ ra: N/A" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
			   </children>
			</GridPane>
             <TableView fx:id="tblHoaDon" prefHeight="250.0">
                 <columns>
                     <TableColumn text="STT" prefWidth="30"/><TableColumn text="Tên món" prefWidth="110"/><TableColumn text="SL" prefWidth="30"/><TableColumn text="Đơn giá" prefWidth="90"/><TableColumn text="Thành tiền" prefWidth="100"/>
                 </columns>
             </TableView>
             <VBox spacing="4" styleClass="receipt-summary">
			     <HBox><Label text="Tổng cộng món ăn:" styleClass="receipt-summary-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblTongTienMonAn" text="0 Đ"/></HBox>
			     <HBox><Label text="Phí dịch vụ (5%):" styleClass="receipt-summary-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblPhiDichVu" text="0 Đ"/></HBox>
			     <HBox><Label text="Thuế VAT (8%):" styleClass="receipt-summary-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblThueVAT" text="0 Đ"/></HBox>
			     <HBox><Label text="Tiền đặt cọc:" styleClass="receipt-summary-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblTienCocSummary" text="0 Đ"/></HBox>
			</VBox>
			<VBox spacing="8">
                 <Label text="Khuyến mãi:" styleClass="receipt-title"/>
                 <ComboBox fx:id="promoComboBox" prefWidth="Infinity" styleClass="promo-combo-box" />
			     <HBox><Label text="Khuyến mãi:" styleClass="receipt-summary-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblKhuyenMai" text="0 Đ"/></HBox>
			</VBox>
			<HBox styleClass="receipt-total">
			    <Label text="Tổng tiền thanh toán:" styleClass="receipt-total-label"/>
			    <Region HBox.hgrow="ALWAYS"/>
			    <Label fx:id="lblTongTienThanhToan" text="0 Đ" styleClass="receipt-total-value"/>
			</HBox>
             <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
               <Button fx:id="btnInHoaDon" text="In hóa đơn" styleClass="print-button"/>
             </HBox> 
             <Label text="CHỌN PHƯƠNG THỨC THANH TOÁN" styleClass="receipt-title" alignment="CENTER"/>
			<HBox spacing="10" alignment="CENTER">
                 <ToggleButton fx:id="btnTienMat" text="Tiền mặt" styleClass="payment-method-button, cash"/>
                 <ToggleButton fx:id="btnNganHang" text="Ngân hàng" styleClass="payment-method-button, bank"/>
                 <ToggleButton fx:id="btnMoMo" text="MoMo" styleClass="payment-method-button, momo"/>
             </HBox>
         </VBox>
      </content>
    </ScrollPane>
</HBox>